# Test database connection.
# Integration tests need a running PostgreSQL 16+ database.
# shikoko resolves the connection using this precedence:
#   1. DATABASE_URL
#   2. Individual PGHOST / PGPORT / PGUSER / PGPASSWORD / PGDATABASE vars
#   3. Defaults (localhost:5432, user postgres)

DATABASE_URL=postgresql://user:password@localhost:5432/testdb
